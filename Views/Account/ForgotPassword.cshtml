@model ArcadeProject.DTOs.AccountDTO.ForgotPasswordDto
@{ ViewData["Title"] = "Resetuj hasło"; }

<link rel="stylesheet" href="~/css/auth.css" asp-append-version="true"/>

<div class="auth-page">
    <div class="auth-card">
        <h1 class="auth-title">RESET HASŁA</h1>
        <p class="auth-sub">
            Podaj email przypisany do konta — wyślemy link do ustawienia nowego hasła.<br>
            <a asp-action="Login">Wróć do logowania</a>
        </p>

        <form class="auth-form" asp-action="ForgotPassword" method="post">
            @Html.AntiForgeryToken()

            <div class="form-field">
                <label class="form-label" asp-for="Email">EMAIL</label>
                <input class="form-input" asp-for="Email"
                       type="email" placeholder="twoj@email.pl"
                       autocomplete="email" autofocus/>
                <span class="field-error" asp-validation-for="Email"></span>
            </div>

            <button type="submit" class="btn-auth btn-auth-primary">WYŚLIJ LINK</button>
        </form>
    </div>
</div>