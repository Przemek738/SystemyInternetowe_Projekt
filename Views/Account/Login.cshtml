@model ArcadeProject.DTOs.AccountDTO.LoginDto
@{ ViewData["Title"] = "Logowanie"; }

<link rel="stylesheet" href="~/css/auth.css" asp-append-version="true"/>

<div class="auth-page">
    <div class="auth-card">
        <h1 class="auth-title">LOGOWANIE</h1>
        <p class="auth-sub">
            Nie masz konta?
            <a asp-action="Register">Zarejestruj się</a>
        </p>

        @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
        {
            <div class="auth-errors mb-3">
                @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <span>@err.ErrorMessage</span>
                }
            </div>
        }

        <form class="auth-form" asp-action="Login" method="post"
              asp-route-returnUrl="@ViewData["ReturnUrl"]">
            @Html.AntiForgeryToken()

            <div class="form-field">
                <label class="form-label" asp-for="UsernameOrEmail">NAZWA UŻYTKOWNIKA LUB EMAIL</label>
                <input class="form-input @(ViewData.ModelState["UsernameOrEmail"]?.Errors.Count > 0 ? "is-invalid" : "")"
                       asp-for="UsernameOrEmail" placeholder="Wpisz login lub email"
                       autocomplete="username" autofocus/>
                <span class="field-error" asp-validation-for="UsernameOrEmail"></span>
            </div>

            <div class="form-field">
                <div style="display:flex; justify-content:space-between; align-items:center">
                    <label class="form-label" asp-for="Password">HASŁO</label>
                    <a class="forgot-link" asp-action="ForgotPassword">Zapomniałem hasła</a>
                </div>
                <div class="input-password-wrapper">
                    <input class="form-input @(ViewData.ModelState["Password"]?.Errors.Count > 0 ? "is-invalid" : "")"
                           asp-for="Password" type="password" id="passwordInput"
                           placeholder="Twoje hasło" autocomplete="current-password"/>
                    <button type="button" class="btn-toggle-password"
                            onclick="togglePassword('passwordInput', this)">👁</button>
                </div>
                <span class="field-error" asp-validation-for="Password"></span>
            </div>

            <div class="form-check">
                <input type="checkbox" asp-for="RememberMe" id="rememberMe"/>
                <label for="rememberMe">Zapamiętaj mnie</label>
            </div>

            <button type="submit" class="btn-auth btn-auth-primary">ZALOGUJ SIĘ</button>
        </form>
    </div>
</div>

@section Scripts {
<script>
    function togglePassword(inputId, btn) {
        const input = document.getElementById(inputId);
        input.type  = input.type === 'password' ? 'text' : 'password';
        btn.textContent = input.type === 'password' ? '👁' : '🙈';
    }
</script>
}