@model ArcadeProject.DTOs.AccountDTO.RegisterDto
@{ ViewData["Title"] = "Rejestracja"; }

<link rel="stylesheet" href="~/css/auth.css" asp-append-version="true"/>

<div class="auth-page">
    <div class="auth-card">
        <h1 class="auth-title">UTWÓRZ KONTO</h1>
        <p class="auth-sub">
            Masz już konto?
            <a asp-action="Login">Zaloguj się</a>
        </p>

        @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
        {
            <div class="auth-errors mb-3">
                @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <span>@err.ErrorMessage</span>
                }
            </div>
        }

        <form class="auth-form" asp-action="Register" method="post">
            @Html.AntiForgeryToken()

            <div class="form-field">
                <label class="form-label" asp-for="Username">NAZWA UŻYTKOWNIKA</label>
                <input class="form-input @(ViewData.ModelState["Username"]?.Errors.Count > 0 ? "is-invalid" : "")"
                       asp-for="Username" placeholder="np. arcadeMaster99" autocomplete="username"/>
                <span class="field-error" asp-validation-for="Username"></span>
            </div>

            <div class="form-field">
                <label class="form-label" asp-for="Email">EMAIL</label>
                <input class="form-input @(ViewData.ModelState["Email"]?.Errors.Count > 0 ? "is-invalid" : "")"
                       asp-for="Email" type="email" placeholder="twoj@email.pl" autocomplete="email"/>
                <span class="field-error" asp-validation-for="Email"></span>
            </div>

            <div class="form-field">
                <label class="form-label" asp-for="Password">HASŁO</label>
                <div class="input-password-wrapper">
                    <input class="form-input @(ViewData.ModelState["Password"]?.Errors.Count > 0 ? "is-invalid" : "")"
                           asp-for="Password" type="password" id="passwordInput"
                           placeholder="Minimum 6 znaków" autocomplete="new-password"/>
                    <button type="button" class="btn-toggle-password" onclick="togglePassword('passwordInput', this)">👁</button>
                </div>
                <span class="field-error" asp-validation-for="Password"></span>
            </div>

            <div class="form-field">
                <label class="form-label" asp-for="ConfirmPassword">POTWIERDŹ HASŁO</label>
                <div class="input-password-wrapper">
                    <input class="form-input @(ViewData.ModelState["ConfirmPassword"]?.Errors.Count > 0 ? "is-invalid" : "")"
                           asp-for="ConfirmPassword" type="password" id="confirmPasswordInput"
                           placeholder="Powtórz hasło" autocomplete="new-password"/>
                    <button type="button" class="btn-toggle-password" onclick="togglePassword('confirmPasswordInput', this)">👁</button>
                </div>
                <span class="field-error" asp-validation-for="ConfirmPassword"></span>
            </div>

            <button type="submit" class="btn-auth btn-auth-primary">ZAREJESTRUJ SIĘ</button>
        </form>
    </div>
</div>

@section Scripts {
    <script>
    function togglePassword(inputId, btn) {
        const input = document.getElementById(inputId);
        if (input.type === 'password') {
            input.type = 'text';
            btn.textContent = '🙈';
        } else {
            input.type = 'password';
            btn.textContent = '👁';
        }
    }
</script>
    
}