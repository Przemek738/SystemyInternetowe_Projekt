@model ArcadeProject.DTOs.AccountDTO.ResetPasswordDto
@{ ViewData["Title"] = "Nowe hasło"; }

<link rel="stylesheet" href="~/css/auth.css" asp-append-version="true"/>

<div class="auth-page">
    <div class="auth-card">
        <h1 class="auth-title">NOWE HASŁO</h1>
        <p class="auth-sub">Ustaw nowe hasło dla swojego konta.</p>

        @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
        {
            <div class="auth-errors mb-3">
                @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <span>@err.ErrorMessage</span>
                }
            </div>
        }

        <form class="auth-form" asp-action="ResetPassword" method="post">
            @Html.AntiForgeryToken()
            
            <input type="hidden" asp-for="UserId"/>
            <input type="hidden" asp-for="Token"/>

            <div class="form-field">
                <label class="form-label" asp-for="NewPassword">NOWE HASŁO</label>
                <div class="input-password-wrapper">
                    <input class="form-input" asp-for="NewPassword" type="password"
                           id="newPassword" placeholder="Minimum 6 znaków"
                           autocomplete="new-password"/>
                    <button type="button" class="btn-toggle-password"
                            onclick="togglePassword('newPassword', this)">👁</button>
                </div>
                <span class="field-error" asp-validation-for="NewPassword"></span>
            </div>

            <div class="form-field">
                <label class="form-label" asp-for="ConfirmPassword">POTWIERDŹ HASŁO</label>
                <div class="input-password-wrapper">
                    <input class="form-input" asp-for="ConfirmPassword" type="password"
                           id="confirmPassword" placeholder="Powtórz hasło"
                           autocomplete="new-password"/>
                    <button type="button" class="btn-toggle-password"
                            onclick="togglePassword('confirmPassword', this)">👁</button>
                </div>
                <span class="field-error" asp-validation-for="ConfirmPassword"></span>
            </div>

            <button type="submit" class="btn-auth btn-auth-primary">ZMIEŃ HASŁO</button>
        </form>
    </div>
</div>

@section Scripts {
<script>
function togglePassword(id, btn) {
    const input = document.getElementById(id);
    input.type  = input.type === 'password' ? 'text' : 'password';
    btn.textContent = input.type === 'password' ? '👁' : '🙈';
}
</script>
}