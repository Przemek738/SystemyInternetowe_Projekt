@model ArcadeProject.DTOs.HomeIndexDto
@{
    ViewData["Title"] = "Strona główna";
}

<link rel="stylesheet" href="~/css/home.css" asp-append-version="true"/>

<section class="hero">
    <div class="hero-label">// Witaj na portalu</div>
    <h1>Graj. Rywalizuj.<br><span>Zostaw swój ślad.</span></h1>
    <p>Klasyczne gry przeglądarkowe z globalnym rankingiem, historią rozgrywek i systemem odznak.</p>

    <div class="d-flex gap-3 flex-wrap">
        <a asp-controller="Game" asp-action="Index" class="btn-arcade btn-primary-arcade">Przeglądaj gry</a>
        @if (User.Identity is { IsAuthenticated: true })
        {
            <a asp-controller="Leaderboard" asp-action="Index" class="btn-arcade btn-ghost-arcade">Ranking globalny</a>
        }
        else
        {
            <a asp-controller="Account" asp-action="Register" class="btn-arcade btn-ghost-arcade">Zarejestruj się</a>
        }
    </div>

</section>

<div class="stats-bar">
    <div class="stat-item">
        <span class="stat-value">@Model.TotalGames</span>
        <div class="stat-label">Gier dostępnych</div>
    </div>
    <div class="stat-item">
        <span class="stat-value">@Model.TotalSessions</span>
        <div class="stat-label">Rozegranych partii</div>
    </div>
    <div class="stat-item">
        <span class="stat-value">@Model.TotalUsers</span>
        <div class="stat-label">Zarejestrowanych graczy</div>
    </div>
    <div class="stat-item">
        <span class="stat-value">@Model.TotalThreads</span>
        <div class="stat-label">Wątków na forum</div>
    </div>
</div>

<div class="section-title">DOSTĘPNE GRY</div>

@if (Model.Games.Any())
{
    <div class="game-grid">
        @foreach (var game in Model.Games)
        {
            <a class="game-card" asp-controller="Game" asp-action="Play" asp-route-slug="@game.Slug">
                @if (!string.IsNullOrEmpty(game.ThumbnailUrl))
                {
                    <img class="game-thumb" src="@game.ThumbnailUrl" alt="@game.Title"/>
                }
                else
                {
                    <div class="game-thumb-placeholder">
                        @(game.Slug switch {
                            "snake"  => "🐍",
                            "tetris" => "🟦",
                            "flappy" => "🐦",
                            _        => "🕹️"
                        })
                    </div>
                }
                <div class="game-body">
                    <div class="game-title">@game.Title</div>
                    <div class="game-desc">@game.Description</div>
                    <div class="game-meta">
                        <div class="game-plays">Grano: <span>@game.TotalSessions</span>×</div>
                        <div class="play-btn">GRAJ &gt;</div>
                    </div>
                </div>
            </a>
        }
    </div>
}
else
{
    <div class="empty-state">
        <div class="icon">🕹️</div>
        <p>Brak gier — administrator wkrótce doda pierwsze tytuły.</p>
    </div>
}

<div class="forum-teaser">
    <div class="forum-teaser-text">
        <h3>FORUM GRACZY</h3>
        <p>Podziel się strategią, zgłoś buga albo po prostu pogadaj o grach z innymi graczami.</p>
    </div>
    <a asp-controller="Forum" asp-action="Index" class="btn-arcade btn-ghost-arcade">Przejdź do forum</a>
</div>
