@model ArcadeProject.DTOs.ChangePasswordDto
@{ ViewData["Title"] = "Zmień hasło"; }

<link rel="stylesheet" href="~/css/profile.css" asp-append-version="true"/>

<div style="max-width:600px;margin:2rem auto">
    <div class="content-card">
        <div class="content-card-header">ZMIEŃ HASŁO</div>
        <div class="content-card-body">

            @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
            {
                <div style="background:rgba(248,113,113,.08);border:1px solid rgba(248,113,113,.25);
                            border-radius:8px;padding:.75rem 1rem;font-size:.82rem;
                            color:#f87171;margin-bottom:1rem">
                    @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div>@err.ErrorMessage</div>
                    }
                </div>
            }

            <form class="settings-form" asp-action="ChangePassword" method="post">
                @Html.AntiForgeryToken()

                <div class="settings-field">
                    <label class="settings-label" asp-for="CurrentPassword">OBECNE HASŁO</label>
                    <input class="settings-input" asp-for="CurrentPassword"
                           type="password" autocomplete="current-password"/>
                    <span class="field-error" asp-validation-for="CurrentPassword"></span>
                </div>

                <div class="settings-field">
                    <label class="settings-label" asp-for="NewPassword">NOWE HASŁO</label>
                    <input class="settings-input" asp-for="NewPassword"
                           type="password" autocomplete="new-password"/>
                    <span class="field-error" asp-validation-for="NewPassword"></span>
                </div>

                <div class="settings-field">
                    <label class="settings-label" asp-for="ConfirmPassword">POTWIERDŹ HASŁO</label>
                    <input class="settings-input" asp-for="ConfirmPassword"
                           type="password" autocomplete="new-password"/>
                    <span class="field-error" asp-validation-for="ConfirmPassword"></span>
                </div>

                <div class="settings-actions">
                    <button type="submit" class="btn-settings-save">ZMIEŃ HASŁO</button>
                    <a class="btn-settings-cancel" asp-action="Index">ANULUJ</a>
                </div>
            </form>
        </div>
    </div>
</div>