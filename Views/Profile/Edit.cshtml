@model ArcadeProject.DTOs.EditProfileDto
@{ ViewData["Title"] = "Edytuj profil"; }

<link rel="stylesheet" href="~/css/profile.css" asp-append-version="true"/>

<div style="max-width:600px;margin:2rem auto">
    <div class="content-card">
        <div class="content-card-header">EDYTUJ PROFIL</div>
        <div class="content-card-body">
            <form class="settings-form" asp-action="Edit" method="post">
                @Html.AntiForgeryToken()

                <div class="settings-field">
                    <label class="settings-label" asp-for="Username">NAZWA UŻYTKOWNIKA</label>
                    <input class="settings-input" asp-for="Username" autocomplete="username"/>
                    <span class="field-error" asp-validation-for="Username"></span>
                </div>

                <div class="settings-field">
                    <label class="settings-label" asp-for="AvatarUrl">URL AVATARA (opcjonalnie)</label>
                    <input class="settings-input" asp-for="AvatarUrl"
                           placeholder="https://..." type="url"/>
                    <span class="field-error" asp-validation-for="AvatarUrl"></span>
                </div>

                <div class="settings-actions">
                    <button type="submit" class="btn-settings-save">ZAPISZ</button>
                    <a class="btn-settings-cancel" asp-action="Index">ANULUJ</a>
                </div>
            </form>
        </div>
    </div>
</div>